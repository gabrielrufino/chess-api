{
  "name": "@servicespack/chess-api",
  "version": "0.0.1",
  "description": "Free API for Chess",
  "author": "Gabriel Rufino <contato@gabrielrufino.com>",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "docs": "npx @compodoc/compodoc -p tsconfig.json -s",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "migration:create": "typeorm migration:create --dir ./src/migrations --name",
    "migration:run": "npm run build && typeorm migration:run --config ./ormconfig.json",
    "migration:revert": "npm run build && typeorm migration:revert --config ./ormconfig.json",
    "reinstall": "rimraf node_modules && npm ci",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:cov": "npm run test:e2e -- --coverage",
    "test:e2e:watch": "npm run test:e2e -- --watch"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/terminus": "^10.2.0",
    "@nestjs/typeorm": "^10.0.1",
    "chess.js": "^0.13.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "helmet": "^5.1.1",
    "nestjs-pino": "^3.5.0",
    "pg": "^8.11.3",
    "pino-http": "^8.6.1",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^4.6.3",
    "typeorm": "^0.3.19"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.1.23",
    "@faker-js/faker": "^6.3.1",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.3",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "pino-pretty": "^10.3.1",
    "prettier": "^3.2.2",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.20",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "src/(.*)": "<rootDir>/src/../$1"
    }
  }
}
